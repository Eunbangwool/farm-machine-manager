<?xml version="1.0" encoding="utf-8"?>
<!-- 지게차 아이콘 (24x24)
     캐빈(운전석) + 본체 + 후륜 + 전륜 + 앞쪽 수직 마스트 + 포크 -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- 앞 마스트 (수직 기둥 두 줄) -->
    <path
        android:fillColor="#000000"
        android:pathData="M3,4 L3.8,4 L3.8,20 L3,20 Z
                          M4.4,4 L5.2,4 L5.2,20 L4.4,20 Z" />
    <!-- 포크 (수평 두 갈래) -->
    <path
        android:fillColor="#000000"
        android:pathData="M1,18.5 L4,18.5 L4,19.5 L1,19.5 Z
                          M1,15 L4,15 L4,16 L1,16 Z" />
    <!-- 캐빈 + 본체 -->
    <path
        android:fillColor="#000000"
        android:pathData="M6,5 L13,5 L13,11 L17,11 L17,17 L6,17 Z
                          M8,7 L12,7 L12,10 L8,10 Z" />
    <!-- 후륜 (큰) -->
    <path
        android:fillColor="#000000"
        android:pathData="M13,19 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0
                          M15,19 a1,1 0 1,0 2,0 a1,1 0 1,0 -2,0" />
    <!-- 전륜 (중) -->
    <path
        android:fillColor="#000000"
        android:pathData="M6,19.5 a2.2,2.2 0 1,0 4.4,0 a2.2,2.2 0 1,0 -4.4,0
                          M7.6,19.5 a0.7,0.7 0 1,0 1.4,0 a0.7,0.7 0 1,0 -1.4,0" />
</vector>
